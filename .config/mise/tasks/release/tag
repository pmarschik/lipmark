#!/usr/bin/env bash
#MISE description="Commit, tag, and push the prepared release (run after release:prepare)"
set -euo pipefail

bold='\033[1m'; cyan='\033[36m'; green='\033[32m'; yellow='\033[33m'; red='\033[31m'; reset='\033[0m'
info()    { echo -e "  ${cyan}${bold}❯${reset}  $*"; }
success() { echo -e "  ${green}✔${reset}  $*"; }
warn()    { echo -e "  ${yellow}⚠${reset}  $*"; }
die()     { echo -e "  ${red}✖${reset}  $*" >&2; exit 1; }
confirm() {
  [[ -t 0 ]] || return 0  # non-interactive: proceed automatically
  echo -e "  ${yellow}${bold}?${reset}  $1 ${bold}[y/N]${reset} \c"
  read -r answer
  [[ "${answer,,}" == "y" ]]
}

echo ""
echo -e "${bold}🏷️  Tagging release…${reset}"
echo ""

# ── detect VCS ───────────────────────────────────────────────────────────
if jj root &>/dev/null; then
  VCS=jj
elif git rev-parse --git-dir &>/dev/null; then
  VCS=git
else
  die "not in a git or jj repository"
fi
info "VCS: ${VCS}"

# ── defensive checks ─────────────────────────────────────────────────────
if [[ "${VCS}" == "git" ]]; then
  branch=$(git branch --show-current)
  [[ "${branch}" == "main" || "${branch}" == "master" ]] \
    || die "must be on main/master branch (current: ${branch})"
  dirty=$(git status --porcelain | grep -v '^\?\?' | grep -v 'CHANGELOG.md' || true)
  [[ -z "${dirty}" ]] \
    || die "unexpected uncommitted changes — only CHANGELOG.md expected:\n${dirty}"
fi

[[ -n "$(git diff HEAD -- CHANGELOG.md 2>/dev/null || git status --porcelain CHANGELOG.md)" ]] \
  || die "CHANGELOG.md has no pending changes — run 'mise run release:prepare' first"

# ── resolve version ──────────────────────────────────────────────────────
JJ_HEAD=""
if [[ "${VCS}" == "jj" ]]; then
  JJ_HEAD=$(jj log -r @ --no-graph --template 'commit_id' 2>/dev/null || true)
fi
raw_version=$(git cliff --config .config/cliff.toml --bumped-version ${JJ_HEAD} 2>/dev/null || die "could not determine version from git cliff")
version="v${raw_version#v}"  # ensure v prefix
info "Version: ${bold}${version}${reset}"

# ── extract highlights from CHANGELOG.md ─────────────────────────────────
# Highlights are text between the first version header (## [...]) and the
# first section header (###). Empty if no highlights were set during prepare.
HIGHLIGHTS=$(awk '/^## \[/{found=1; next} found && /^###/{exit} found && NF{print}' CHANGELOG.md | sed 's/^[[:space:]]*//')

if [[ -n "${HIGHLIGHTS}" ]]; then
  info "Highlights: ${HIGHLIGHTS}"
fi
echo ""

# ── confirm ──────────────────────────────────────────────────────────────
confirm "Commit, tag ${version}, and push?" \
  || { warn "Aborted."; echo ""; exit 0; }
echo ""

# ── commit ───────────────────────────────────────────────────────────────
if [[ "${VCS}" == "jj" ]]; then
  jj describe -m "chore(release): ${version}"
else
  git add CHANGELOG.md
  git commit -m "chore(release): ${version}"
fi
success "Committed: chore(release): ${version}"

# ── tag ──────────────────────────────────────────────────────────────────
if [[ "${VCS}" == "jj" ]]; then
  # Capture commit ID before tagging — jj tag set makes @ immutable and moves @ to a new empty commit.
  RELEASE_COMMIT=$(jj log -r @ --no-graph --template 'commit_id')
  jj tag set "${version}"
  # jj creates lightweight tags; replace with annotated git tag for cliff highlights
  if [[ -n "${HIGHLIGHTS}" ]]; then
    git tag -f -a "${version}" -m "${HIGHLIGHTS}" "${RELEASE_COMMIT}"
  fi
else
  if [[ -n "${HIGHLIGHTS}" ]]; then
    git tag -a "${version}" -m "${HIGHLIGHTS}"
  else
    git tag "${version}"
  fi
fi
if [[ -n "${HIGHLIGHTS}" ]]; then
  success "Tagged: ${version} (annotated)"
else
  success "Tagged: ${version}"
fi

# ── push ─────────────────────────────────────────────────────────────────
if [[ "${VCS}" == "jj" ]]; then
  echo ""
  echo "Push the release (requires hardware key):"
  echo "  jj git push --all"
  echo "  git push --tags"
else
  git push --follow-tags
fi

echo ""
echo -e "  ${green}${bold}🚀 GitHub Actions will create the release automatically.${reset}"
echo ""
